<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_light_1">

    <ImageView
        android:id="@+id/logoMaintenance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/logo_description"
        android:src="@drawable/logo_main"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="70dp"/>

    <TextView
        android:id="@+id/txtMaintenance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/logoMaintenance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"
        android:textColor="@color/gray_light_2"
        android:textSize="25sp"
        android:text="@string/maintenance"
        android:fontFamily="@font/poppins_bold"
        android:letterSpacing=".1"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/txtMaintenance1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/txtMaintenance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"
        android:textColor="@color/blue_light_2"
        android:textSize="25sp"
        android:text="@string/maintenance_1"
        android:fontFamily="@font/poppins_bold"
        android:letterSpacing=".1"
        android:textAlignment="center"/>

</androidx.constraintlayout.widget.ConstraintLayout>